# ─── PostgreSQL Database ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=airman_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── Skynet Node.js Service ───────────────────────────────────────────────────
PORT=3000

# ─── Maverick FastAPI Service ─────────────────────────────────────────────────
# Used by Skynet to communicate with Maverick inside Docker
MAVERICK_URL=http://maverick:8000